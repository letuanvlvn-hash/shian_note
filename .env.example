# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GOOGLE_SHEETS_API_URL: The URL of the Google Apps Script Web App for data synchronization.
GOOGLE_SHEETS_API_URL="https://script.google.com/macros/s/AKfycbyOmkz6kSjI0-Qf7mQpoqZxx4jXyk8IqJwIOoHyLKlQHaEhKt_zpEX03K2S_9MbCsYT/exec"

# IMGBB_API_KEY: Required for image uploads (Prompt Library)
VITE_IMGBB_API_KEY=
